# backstage-cba-prep — environment template.
# Copy to `.env` (gitignored) and fill in locally. NEVER commit real
# credentials, AWS account IDs, or profile names — keep them out of the repo.
# Validate config shape without spending tokens:  node bin/cli.js bedrock-check

# --- LLM backend selection ---
# anthropic = first-party Anthropic API (default) | bedrock = AWS Bedrock
LLM_BACKEND=anthropic

# --- First-party Anthropic API (LLM_BACKEND=anthropic) ---
ANTHROPIC_API_KEY=
# Optional per-tier overrides (sensible defaults are built in):
# MODEL_FAST=claude-haiku-4-5
# MODEL_STANDARD=claude-sonnet-5
# MODEL_CRITICAL=claude-opus-4-8

# --- AWS Bedrock (LLM_BACKEND=bedrock) ---
# Keep account/profile LOCAL. Use your own SSO profile name, not a real one in git.
AWS_PROFILE=your-sso-profile
AWS_REGION=us-east-1
# Cross-region inference-profile ids (from: aws bedrock list-inference-profiles).
# Verified ACTIVE in us-east-1. Both us.* (US routing, default) and global.*
# (worldwide, a later switch) exist for all three. Ids are not uniformly versioned.
BEDROCK_MODEL_FAST=us.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_MODEL_STANDARD=us.anthropic.claude-sonnet-5
BEDROCK_MODEL_CRITICAL=us.anthropic.claude-opus-4-8

# Workload → tier mapping (consumed by the future Bedrock adapter, #23):
#   fast     → high-volume learner/coach flow
#   standard → generate + blueprint authoring/extraction
#   critical → review-bank --ai semantic verification
