{
  "name": "backstage-cba-prep",
  "version": "0.1.0",
  "description": "Engine-neutral study kit for the Certified Backstage Associate (CBA) exam: timed mock simulator, multi-provider AI question generator, and a doc-grounded question bank. Works with Claude Code, OpenAI Codex, and Gemini CLI.",
  "type": "module",
  "bin": {
    "backstage-cba-prep": "bin/cli.js",
    "cba-prep": "bin/cli.js"
  },
  "scripts": {
    "exam": "node bin/cli.js exam",
    "generate": "node bin/cli.js generate",
    "validate": "node bin/cli.js validate",
    "stats": "node bin/cli.js stats",
    "sync": "node bin/cli.js sync",
    "audit": "node bin/cli.js audit-sources",
    "review": "node bin/cli.js review-bank",
    "history": "node bin/cli.js history",
    "blueprint": "node bin/cli.js blueprint",
    "bedrock-check": "node bin/cli.js bedrock-check",
    "agent-check": "node bin/cli.js agent-check",
    "agent-refresh": "node bin/cli.js agent-refresh",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "questions",
    "spec",
    "!spec/product-roadmap.md",
    "!spec/domain-driven-design.md",
    ".env.example",
    "workflows",
    "AGENTS.md",
    "CLAUDE.md",
    ".claude",
    ".gemini",
    ".github",
    "test",
    "RELEASE.md",
    "melhorias.md",
    "inconsistencias.md"
  ],
  "keywords": [
    "backstage",
    "cba",
    "certification",
    "linux-foundation",
    "cncf",
    "exam",
    "quiz",
    "developer-portal",
    "study",
    "codex",
    "gemini",
    "claude"
  ],
  "author": "",
  "license": "MIT",
  "optionalDependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1079.0",
    "@strands-agents/sdk": "^1.7.0",
    "zod": "^4.4.3"
  }
}
